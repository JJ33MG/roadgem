// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  password            String
  name                String
  createdAt           DateTime  @default(now())
  subscriptionTier    String    @default("free")
  subscriptionExpires DateTime?

  trips Trip[]
}

model Trip {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  startLocation String
  destination   String
  startDate     String
  endDate       String
  days          Int
  budget        Float
  travelStyle   String
  priorities    String
  totalCost     Float
  totalDistance Float
  stops         String
  highlights    String
  tips          String
  weather       String
  hiddenGems    String?
  createdAt     DateTime @default(now())

  itineraryDays TripDay[]
  bookings      Booking[]
}

model Booking {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId    String?
  type      String
  bookingId String
  cost      Float    @default(0)
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model TripDay {
  id     String @id @default(cuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  day    Int

  activities TripActivity[]
}

model TripActivity {
  id            String  @id @default(cuid())
  tripDayId     String
  tripDay       TripDay @relation(fields: [tripDayId], references: [id], onDelete: Cascade)
  slot          String
  time          String
  activity      String
  location      String
  description   String
  estimatedCost Float
  notes         String
}

model DestinationGem {
  id          String   @id @default(cuid())
  destination String
  name        String
  description String
  address     String
  category    String
  whyHidden   String
  photoUrl    String?
  createdAt   DateTime @default(now())

  @@index([destination])
}

model AgentRun {
  id          String   @id @default(cuid())
  agentName   String
  status      String   @default("running")
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  result      String?
  error       String?
  logs        AgentLog[]
}

model AgentLog {
  id        String   @id @default(cuid())
  runId     String
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  level     String   @default("info")
  message   String
  data      String?
  createdAt DateTime @default(now())
}
