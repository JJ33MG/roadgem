// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  password            String
  name                String
  createdAt           DateTime  @default(now())
  subscriptionTier    String    @default("free")
  subscriptionExpires DateTime?

  trips         Trip[]
  communityGems CommunityGem[]
}

model Trip {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  startLocation String
  destination   String
  startDate     String
  endDate       String
  days          Int
  budget        Float
  travelStyle   String
  priorities    String
  totalCost     Float
  totalDistance Float
  stops         String
  highlights    String
  tips          String
  weather       String
  hiddenGems    String?
  fromTemplate  String?
  createdAt     DateTime @default(now())

  itineraryDays TripDay[]
  bookings      Booking[]
}

model Booking {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId    String?
  type      String
  bookingId String
  cost      Float    @default(0)
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model TripDay {
  id     String @id @default(cuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  day    Int

  activities TripActivity[]
}

model TripActivity {
  id            String  @id @default(cuid())
  tripDayId     String
  tripDay       TripDay @relation(fields: [tripDayId], references: [id], onDelete: Cascade)
  slot          String
  time          String
  activity      String
  location      String
  description   String
  estimatedCost Float
  notes         String
}

model AgentMessage {
  id          String   @id @default(cuid())
  fromAgent   String
  toAgent     String
  type        String
  payload     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([toAgent, read])
}

model DestinationGem {
  id          String   @id @default(cuid())
  destination String
  name        String
  description String
  address     String
  latitude    Float?
  longitude   Float?
  category    String
  whyHidden   String
  photoUrl    String?
  createdAt   DateTime @default(now())

  @@index([destination])
}

model CommunityGem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  category    String
  location    String
  description String
  status      String   @default("pending") // pending | approved | rejected
  aiScore     Int      @default(0)
  aiFeedback  String   @default("")
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([status])
}

model TripTemplate {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String
  emoji         String   @default("🗺️")
  startLocation String
  destination   String
  days          Int
  budget        Float
  travelStyle   String
  highlights    String
  stops         String
  itinerary     String
  tips          String
  totalCost     Float
  totalDistance Float    @default(0)
  priceEur      Float    @default(4.99)
  featured      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([slug])
  @@index([featured])
}

model TemplatePurchase {
  id         String   @id @default(cuid())
  userId     String
  templateId String
  stripeId   String?
  createdAt  DateTime @default(now())

  @@unique([userId, templateId])
  @@index([userId])
}

model DestinationQueue {
  id             String    @id @default(cuid())
  destination    String    @unique
  country        String
  gemDepth       Int       @default(0)   // 0=untouched, 1=6gems, 2=12gems, 3=20+gems
  seoGenerated   Boolean   @default(false)
  priority       Int       @default(0)   // higher = process first
  source         String    @default("seed") // seed | auto-discovery | trending | user
  addedAt        DateTime  @default(now())
  lastResearched DateTime?

  @@index([gemDepth, priority])
}

model DestinationSeo {
  id                    String   @id @default(cuid())
  destination           String   @unique
  slug                  String   @unique
  title                 String
  metaDescription       String
  h1                    String
  intro                 String
  topKeywords           String
  faq                   String
  internalLinkSuggestions String
  updatedAt             DateTime @updatedAt

  @@index([slug])
}

model AgentRun {
  id          String   @id @default(cuid())
  agentName   String
  status      String   @default("running")
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  result      String?
  error       String?
  logs        AgentLog[]
}

model AgentLog {
  id        String   @id @default(cuid())
  runId     String
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  level     String   @default("info")
  message   String
  data      String?
  createdAt DateTime @default(now())
}
