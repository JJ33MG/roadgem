# ============================
# ROADGEM Environment Variables
# Copy this file to backend/.env and frontend/.env, fill in values.
# ============================

# --- Server ---
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://user:password@localhost:5432/roadgem
PGHOST=localhost
PGPORT=5432
PGUSER=user
PGPASSWORD=password
PGDATABASE=roadgem

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# --- Claude / Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# --- Google APIs ---
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# --- Weather ---
OPENWEATHER_API_KEY=

# --- Affiliates ---
BOOKING_COM_AFFILIATE_ID=

# --- Email ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@roadgem.app

# --- Payments (future) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Cron / Agents ---
ENABLE_CRON_AGENTS=true
LOCATION_RESEARCH_CRON="0 2 * * *"
FUEL_PRICE_UPDATE_CRON="0 */4 * * *"

# ============================
# Frontend (Vite) — must be prefixed with VITE_
# ============================
VITE_API_BASE_URL=http://localhost:4000/api
VITE_GOOGLE_MAPS_API_KEY=
